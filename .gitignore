# For PCBs designed using KiCad: https://www.kicad.org/
# Format documentation: https://kicad.org/help/file-formats/

# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*-cache*
*-bak
*-bak*
*~
~*
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
\#auto_saved_files#

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv

# Archived Backups (KiCad 6.0)
**/*-backups/*.zip
*.zip

# Local git-based history (KiCad 9.0+)
.history

# Local project settings
*.kicad_prl

# 3D STEP exports (component libraries use .stp; board-level export not needed)
*.step

# Fabrication toolkit local settings
fabrication-toolkit-options.json

# Fabrication output backups
production/backups/

# Accidentally extracted repo zip
artermis26-startup-board-main/
